Scene: HierarchyTest
PipelineSettings:
  SkyEnabled: true
  SkyTopColor: [0.25, 0.35, 0.55]
  SkyBottomColor: [0.75, 0.8, 0.9]
  ShadowEnabled: true
  ShadowBias: 0.001
  ShadowNormalBias: 0.02
  ShadowPCFRadius: 1
Entities:
  # ==================== LIGHTING ====================
  - Entity: 900001
    TagComponent:
      Tag: Sun
    TransformComponent:
      Position: [0, 10, 0]
      Rotation: [0, 0, 0]
      Scale: [1, 1, 1]
    DirectionalLightComponent:
      Direction: [0.5, 1.0, 0.3]
      Color: [1.0, 0.95, 0.88]
      Intensity: 1.0

  # ==================== GROUND ====================
  - Entity: 900100
    TagComponent:
      Tag: Ground
    TransformComponent:
      Position: [0, 0, 0]
      Rotation: [0, 0, 0]
      Scale: [25, 0.1, 25]
    MeshRendererComponent:
      MeshType: 2
      Color: [0.45, 0.5, 0.45, 1.0]
      MaterialName: Lit
      CastShadows: false

  # ==================== SOLAR SYSTEM (nested transforms) ====================

  # Sun (root of solar system)
  - Entity: 900200
    TagComponent:
      Tag: Solar System Root
    TransformComponent:
      Position: [-5, 2, 0]
      Rotation: [0, 0, 0]
      Scale: [1, 1, 1]

  # Star
  - Entity: 900201
    Parent: 900200
    TagComponent:
      Tag: Star
    TransformComponent:
      Position: [0, 0, 0]
      Rotation: [0, 0, 0]
      Scale: [1.5, 1.5, 1.5]
    MeshRendererComponent:
      MeshType: 3
      Color: [1.0, 0.9, 0.3, 1.0]
      MaterialName: PBR
      MaterialOverrides:
        - Name: u_EmissionColor
          Type: Vec3
          Value: [1.0, 0.8, 0.2]

  # Planet
  - Entity: 900202
    Parent: 900200
    TagComponent:
      Tag: Planet
    TransformComponent:
      Position: [3, 0, 0]
      Rotation: [0, 0, 15]
      Scale: [0.6, 0.6, 0.6]
    MeshRendererComponent:
      MeshType: 3
      Color: [0.3, 0.5, 0.9, 1.0]
      MaterialName: Lit
      CastShadows: true

  # Moon (child of planet)
  - Entity: 900203
    Parent: 900202
    TagComponent:
      Tag: Moon
    TransformComponent:
      Position: [2, 0.5, 0]
      Rotation: [0, 0, 0]
      Scale: [0.4, 0.4, 0.4]
    MeshRendererComponent:
      MeshType: 3
      Color: [0.7, 0.7, 0.7, 1.0]
      MaterialName: Lit
      CastShadows: true

  # ==================== ROBOT ARM (chain of transforms) ====================

  # Base
  - Entity: 900300
    TagComponent:
      Tag: Robot Base
    TransformComponent:
      Position: [4, 0.5, 0]
      Rotation: [0, 0, 0]
      Scale: [1.5, 1, 1.5]
    MeshRendererComponent:
      MeshType: 2
      Color: [0.5, 0.5, 0.55, 1.0]
      MaterialName: PBR
      CastShadows: true
      MaterialOverrides:
        - Name: u_Metallic
          Type: Float
          Value: 0.8
        - Name: u_Roughness
          Type: Float
          Value: 0.3

  # Lower arm
  - Entity: 900301
    Parent: 900300
    TagComponent:
      Tag: Lower Arm
    TransformComponent:
      Position: [0, 1.2, 0]
      Rotation: [0, 0, 20]
      Scale: [0.3, 2, 0.3]
    MeshRendererComponent:
      MeshType: 2
      Color: [0.8, 0.5, 0.1, 1.0]
      MaterialName: PBR
      CastShadows: true
      MaterialOverrides:
        - Name: u_Metallic
          Type: Float
          Value: 0.7
        - Name: u_Roughness
          Type: Float
          Value: 0.35

  # Upper arm
  - Entity: 900302
    Parent: 900301
    TagComponent:
      Tag: Upper Arm
    TransformComponent:
      Position: [0, 1.5, 0]
      Rotation: [0, 0, -40]
      Scale: [0.8, 1.5, 0.8]
    MeshRendererComponent:
      MeshType: 2
      Color: [0.8, 0.5, 0.1, 1.0]
      MaterialName: PBR
      CastShadows: true
      MaterialOverrides:
        - Name: u_Metallic
          Type: Float
          Value: 0.7
        - Name: u_Roughness
          Type: Float
          Value: 0.35

  # Hand/gripper
  - Entity: 900303
    Parent: 900302
    TagComponent:
      Tag: Gripper
    TransformComponent:
      Position: [0, 1.2, 0]
      Rotation: [0, 0, 10]
      Scale: [1.5, 0.3, 1.5]
    MeshRendererComponent:
      MeshType: 2
      Color: [0.3, 0.3, 0.35, 1.0]
      MaterialName: PBR
      CastShadows: true
      MaterialOverrides:
        - Name: u_Metallic
          Type: Float
          Value: 0.9
        - Name: u_Roughness
          Type: Float
          Value: 0.2

  # ==================== BUILDING (nested hierarchy) ====================

  # Building root
  - Entity: 900400
    TagComponent:
      Tag: Building
    TransformComponent:
      Position: [0, 0, -5]
      Rotation: [0, 15, 0]
      Scale: [1, 1, 1]

  # Base floor
  - Entity: 900401
    Parent: 900400
    TagComponent:
      Tag: Floor 1
    TransformComponent:
      Position: [0, 0.5, 0]
      Rotation: [0, 0, 0]
      Scale: [3, 1, 3]
    MeshRendererComponent:
      MeshType: 2
      Color: [0.6, 0.55, 0.5, 1.0]
      MaterialName: Lit
      CastShadows: true

  # Second floor
  - Entity: 900402
    Parent: 900400
    TagComponent:
      Tag: Floor 2
    TransformComponent:
      Position: [0, 1.5, 0]
      Rotation: [0, 0, 0]
      Scale: [2.5, 1, 2.5]
    MeshRendererComponent:
      MeshType: 2
      Color: [0.55, 0.5, 0.45, 1.0]
      MaterialName: Lit
      CastShadows: true

  # Roof
  - Entity: 900403
    Parent: 900400
    TagComponent:
      Tag: Roof
    TransformComponent:
      Position: [0, 2.5, 0]
      Rotation: [0, 0, 0]
      Scale: [2, 1, 2]
    MeshRendererComponent:
      MeshType: 2
      Color: [0.5, 0.45, 0.4, 1.0]
      MaterialName: Lit
      CastShadows: true

  # Chimney (child of roof)
  - Entity: 900404
    Parent: 900403
    TagComponent:
      Tag: Chimney
    TransformComponent:
      Position: [0.5, 0.9, -0.3]
      Rotation: [0, 0, 0]
      Scale: [0.15, 0.8, 0.15]
    MeshRendererComponent:
      MeshType: 2
      Color: [0.4, 0.3, 0.25, 1.0]
      MaterialName: Lit
      CastShadows: true

  # ==================== MESH TYPE SHOWCASE ====================

  # Triangle (MeshType 0)
  - Entity: 900500
    TagComponent:
      Tag: Triangle (type 0)
    TransformComponent:
      Position: [-6, 1, 5]
      Rotation: [0, 0, 0]
      Scale: [1, 1, 1]
    MeshRendererComponent:
      MeshType: 0
      Color: [1.0, 0.3, 0.3, 1.0]

  # Quad (MeshType 1)
  - Entity: 900501
    TagComponent:
      Tag: Quad (type 1)
    TransformComponent:
      Position: [-3, 1, 5]
      Rotation: [0, 0, 0]
      Scale: [1, 1, 1]
    MeshRendererComponent:
      MeshType: 1
      Color: [0.3, 1.0, 0.3, 1.0]

  # Cube (MeshType 2)
  - Entity: 900502
    TagComponent:
      Tag: Cube (type 2)
    TransformComponent:
      Position: [0, 0.5, 5]
      Rotation: [0, 30, 0]
      Scale: [1, 1, 1]
    MeshRendererComponent:
      MeshType: 2
      Color: [0.3, 0.3, 1.0, 1.0]
      MaterialName: Lit
      CastShadows: true

  # Sphere (MeshType 3)
  - Entity: 900503
    TagComponent:
      Tag: Sphere (type 3)
    TransformComponent:
      Position: [3, 0.5, 5]
      Rotation: [0, 0, 0]
      Scale: [1, 1, 1]
    MeshRendererComponent:
      MeshType: 3
      Color: [1.0, 0.7, 0.2, 1.0]
      MaterialName: Lit
      CastShadows: true

  # ==================== CAMERA ====================
  - Entity: 900900
    TagComponent:
      Tag: Main Camera
      GameObjectTag: MainCamera
    TransformComponent:
      Position: [0, 5, 12]
      Rotation: [-15, 0, 0]
      Scale: [1, 1, 1]
    CameraComponent:
      ProjectionType: Perspective
      FOV: 60
      NearClip: 0.1
      FarClip: 500
      Priority: 0
    AudioListenerComponent: {}
