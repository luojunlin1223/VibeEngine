      Scale: [1, 1, 1]
    MeshRendererComponent:
      MeshType: 3
      Color: [0.95, 0.64, 0.54, 1.0]
      MaterialName: PBR
      CastShadows: true
      MaterialOverrides:
        - Name: u_Metallic
          Type: Float
          Value: 0.8
        - Name: u_Roughness
          Type: Float
          Value: 0.25

  - Entity: 500212
    TagComponent:
      Tag: Rough 0.5
    TransformComponent:
      Position: [0, 0.8, 0]
      Rotation: [0, 0, 0]
      Scale: [1, 1, 1]
    MeshRendererComponent:
      MeshType: 3
      Color: [0.95, 0.64, 0.54, 1.0]
      MaterialName: PBR
      CastShadows: true
      MaterialOverrides:
        - Name: u_Metallic
          Type: Float
          Value: 0.8
        - Name: u_Roughness
          Type: Float
          Value: 0.5

  - Entity: 500213
    TagComponent:
      Tag: Rough 0.75
    TransformComponent:
      Position: [2, 0.8, 0]
      Rotation: [0, 0, 0]
      Scale: [1, 1, 1]
    MeshRendererComponent:
      MeshType: 3
      Color: [0.95, 0.64, 0.54, 1.0]
      MaterialName: PBR
      CastShadows: true
      MaterialOverrides:
        - Name: u_Metallic
          Type: Float
          Value: 0.8
        - Name: u_Roughness
          Type: Float
          Value: 0.75

  - Entity: 500214
    TagComponent:
      Tag: Rough 1.0
    TransformComponent:
      Position: [4, 0.8, 0]
      Rotation: [0, 0, 0]
      Scale: [1, 1, 1]
    MeshRendererComponent:
      MeshType: 3
      Color: [0.95, 0.64, 0.54, 1.0]
      MaterialName: PBR
      CastShadows: true
      MaterialOverrides:
        - Name: u_Metallic
          Type: Float
          Value: 0.8
        - Name: u_Roughness
          Type: Float
          Value: 1.0

  # ==================== COLORED MATERIALS ====================

  # Gold
  - Entity: 500300
    TagComponent:
      Tag: Gold
    TransformComponent:
      Position: [-3, 0.8, 3]
      Rotation: [0, 0, 0]
      Scale: [1, 1, 1]
    MeshRendererComponent:
      MeshType: 3
      Color: [1.0, 0.76, 0.33, 1.0]
      MaterialName: PBR
      CastShadows: true
      MaterialOverrides:
        - Name: u_Metallic
          Type: Float
          Value: 1.0
        - Name: u_Roughness
          Type: Float
          Value: 0.15

  # Copper
  - Entity: 500301
    TagComponent:
      Tag: Copper
    TransformComponent:
      Position: [-1, 0.8, 3]
      Rotation: [0, 0, 0]
      Scale: [1, 1, 1]
    MeshRendererComponent:
      MeshType: 3
      Color: [0.97, 0.74, 0.62, 1.0]
      MaterialName: PBR
      CastShadows: true
      MaterialOverrides:
        - Name: u_Metallic
          Type: Float
          Value: 1.0
        - Name: u_Roughness
          Type: Float
          Value: 0.25

  # Red plastic
  - Entity: 500302
    TagComponent:
      Tag: Red Plastic
    TransformComponent:
      Position: [1, 0.8, 3]
      Rotation: [0, 0, 0]
      Scale: [1, 1, 1]
    MeshRendererComponent:
      MeshType: 3
      Color: [0.9, 0.1, 0.1, 1.0]
      MaterialName: PBR
      CastShadows: true
      MaterialOverrides:
        - Name: u_Metallic
          Type: Float
          Value: 0.02
        - Name: u_Roughness
          Type: Float
          Value: 0.4

  # Emissive
  - Entity: 500303
    TagComponent:
      Tag: Emissive Glow
    TransformComponent:
      Position: [3, 0.8, 3]
      Rotation: [0, 0, 0]
      Scale: [1, 1, 1]
    MeshRendererComponent:
      MeshType: 3
      Color: [0.05, 0.05, 0.05, 1.0]
      MaterialName: PBR
      CastShadows: true
      MaterialOverrides:
        - Name: u_Metallic
          Type: Float
          Value: 0.0
        - Name: u_Roughness
          Type: Float
          Value: 0.5
        - Name: u_EmissionColor
          Type: Vec3
          Value: [0.0, 0.8, 1.0]

  # ==================== CAMERA ====================
  - Entity: 500900
    TagComponent:
      Tag: Main Camera
      GameObjectTag: MainCamera
    TransformComponent:
      Position: [0, 4, 8]
      Rotation: [-20, 0, 0]
      Scale: [1, 1, 1]
    CameraComponent:
      ProjectionType: Perspective
      FOV: 50
      NearClip: 0.1
      FarClip: 500
      Priority: 0
