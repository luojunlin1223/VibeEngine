      MaterialOverrides:
        - Name: u_Metallic
          Type: Float
          Value: 1.0
        - Name: u_Roughness
          Type: Float
          Value: 0.3

  # ==================== ROUGHNESS GRADIENT (front row) ====================
  # Metallic = 0.8, Roughness varies 0.0 -> 1.0

  - Entity: 500210
    TagComponent:
      Tag: Rough 0.05
    TransformComponent:
      Position: [-4, 0.8, 0]
